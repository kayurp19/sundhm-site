# Railway / Caddy v2 config — serves the static site
{
	auto_https off
	admin off
	persist_config off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip
	file_server
	try_files {path} {path}.html /index.html

	# Long cache for fingerprintable static assets
	@assets path *.css *.js *.jpg *.jpeg *.png *.webp *.svg *.woff *.woff2 *.ico
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Short cache for HTML so updates show up quickly
	@html path *.html /
	header @html Cache-Control "public, max-age=300, must-revalidate"

	# Always-fresh for SEO files
	@seo path /sitemap.xml /robots.txt
	header @seo Cache-Control "public, max-age=3600"

	# Security headers (apply to all responses)
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header X-Frame-Options "SAMEORIGIN"
	header Permissions-Policy "camera=(), microphone=(), geolocation=()"
}
